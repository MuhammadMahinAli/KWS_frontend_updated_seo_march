Options -Indexes

RewriteEngine On

# Serve pre-rendered HTML for known routes
# Apache will find the route's directory (e.g. /products/) and serve
# its index.html automatically via DirectoryIndex — no rewrite needed.

# Force HTTPS + canonical www in a single redirect (avoids double-hop)
# Matches if HTTP *or* non-www — always lands on https://www.kws.technology
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^ https://www.kws.technology%{REQUEST_URI} [L,R=301]

# Remove trailing slash (except root)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [L,R=301]

# If the request is for an existing file, serve it directly (assets, images, etc.)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# If the request maps to a pre-rendered directory (e.g. /products -> /products/index.html),
# serve it directly — this is what makes prerendering work.
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Everything else falls back to the root index.html (SPA catch-all)
RewriteRule ^ /index.html [L]

# ── Performance & Security headers ──────────────────────────────────────────

<IfModule mod_headers.c>
  # Cache static assets aggressively (Vite fingerprints filenames)
  <FilesMatch "\.(js|css|woff2?|ttf|otf|eot|png|jpg|jpeg|gif|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Never cache HTML (so updated prerendered pages are always fresh)
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Basic security headers
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Prevent search engines from indexing the hidden admin route
  <If "%{REQUEST_URI} =~ m#^/adminkws22917#">
    Header always set X-Robots-Tag "noindex, nofollow"
  </If>
</IfModule>

# ── Compression ─────────────────────────────────────────────────────────────

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
